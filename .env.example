# Translation engine:
#   google    -> keyless, no signup, uses Google's free web endpoint (default)
#   deepl_api -> official DeepL API, requires DEEPL_API_KEY below
TRANSLATION_ENGINE=google

# Only needed if TRANSLATION_ENGINE=deepl_api (free key: https://www.deepl.com/pro-api)
# DEEPL_API_KEY=your-deepl-api-key-here

# Global hotkey to start a selection
HOTKEY=alt+q

# Optional: full path to tesseract.exe if it is not on your PATH.
# The app auto-detects the default install location, so you usually don't need this.
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
